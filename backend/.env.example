# Copy this file to .env and fill in the values

# Port the API server will listen on (default: 3001)
PORT=3001

# Secret used to sign JWT tokens — change this to a long random string in production!
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret

# Path to the SQLite database file (default: ./healthcare.db)
# DB_PATH=./healthcare.db

# If you serve the frontend from the same Express process, point STATIC_DIR at the folder:
# STATIC_DIR=../frontend

# Restrict CORS to your frontend origin in production:
# FRONTEND_ORIGIN=https://your-app.example.com
